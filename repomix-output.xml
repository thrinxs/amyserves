    color: #276749;
  }
  
  /* ── DIVIDER ─────────────────────────────────────────── */
  .auth-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 24px 0;
    color: var(--warm-grey);
    font-size: 0.82rem;
  }
  
  .auth-divider::before,
  .auth-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  
  /* ── PASSWORD STRENGTH ───────────────────────────────── */
  .password-strength {
    margin-top: 8px;
