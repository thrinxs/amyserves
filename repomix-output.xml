              </div>
              <div class="qf-field">
                <label class="qf-label" for="email">Email address <span class="qf-req">*</span></label>
                <input type="email" id="email" name="email" placeholder="your@email.com" required />
              </div>
            </div>
            <div class="qf-row qf-row-2" style="margin-bottom:28px">
              <div class="qf-field">
                <label class="qf-label" for="phone">Phone number <span class="qf-req">*</span></label>
                <input type="tel" id="phone" name="phone" placeholder="09098104610" required />
              </div>
              <div class="qf-field">
                <label class="qf-label" for="role">Your role / job title</label>
                <input type="text" id="role" name="role" placeholder="e.g. CEO, Office Manager" />
              </div>
            </div>

            <!-- ── SECTION 3: Business -->
            <div class="qf-section-title">3 — About your business</div>

            <div class="qf-row qf-row-2">
              <div class="qf-field">
                <label class="qf-label" for="bizName">Business name <span class="qf-req">*</span></label>
                <input type="text" id="bizName" name="business_name" placeholder="Your company name" required />
              </div>
              <div class="qf-field">
                <label class="qf-label" for="industry">Industry <span class="qf-req">*</span></label>
                <select id="industry" name="industry" required>
                  <option value="" disabled selected>Select industry</option>
                  <option>Banking &amp; Finance</option>
                  <option>Construction &amp; Real Estate</option>
                  <option>Education</option>
                  <option>Energy &amp; Oil</option>
                  <option>Government / Public Sector</option>
                  <option>Healthcare</option>
                  <option>Hospitality &amp; Tourism</option>
                  <option>Legal &amp; Professional Services</option>
                  <option>Logistics &amp; Supply Chain</option>
                  <option>Manufacturing</option>
                  <option>Media &amp; Advertising</option>
                  <option>NGO / Non-Profit</option>
                  <option>Retail &amp; FMCG</option>
                  <option>Technology</option>
                  <option>Telecommunications</option>
                  <option>Other</option>
                </select>
              </div>
            </div>
            <div class="qf-row qf-row-3" style="margin-bottom:28px">
              <div class="qf-field">
                <label class="qf-label" for="location">Location / area <span class="qf-req">*</span></label>
                <input type="text" id="location" name="location" placeholder="e.g. Maitama, Abuja" required />
              </div>
              <div class="qf-field">
                <label class="qf-label" for="staffSize">Team / staff size</label>
                <select id="staffSize" name="staff_size">
                  <option value="" disabled selected>Select range</option>
                  <option>1 – 10 staff</option>
                  <option>11 – 30 staff</option>
                  <option>31 – 100 staff</option>
                  <option>101 – 500 staff</option>
                  <option>500+ staff</option>
                </select>
              </div>
              <div class="qf-field">
                <label class="qf-label" for="urgency">How soon do you need this?</label>
                <select id="urgency" name="urgency">
                  <option value="" disabled selected>Select timeframe</option>
                  <option>As soon as possible</option>
                  <option>Within 1 week</option>
                  <option>Within 2–4 weeks</option>
                  <option>Next month</option>
                  <option>Just exploring options</option>
                </select>
              </div>
            </div>

            <!-- ── SECTION 4: Brief -->
            <div class="qf-section-title">4 — Brief us</div>

            <div class="qf-field" style="margin-bottom:24px">
              <label class="qf-label" for="brief">Tell us more about what you need <span class="qf-req">*</span></label>
              <textarea
                id="brief"
                name="brief"
                placeholder="Describe the scope — space size, frequency, number of staff, current challenges, or anything else that helps us quote accurately..."
                required
              ></textarea>
            </div>

            <div class="qf-checks">
              <label class="qf-check-row">
                <input type="checkbox" name="send_copy" value="Yes" checked />
                <div class="qf-check-text">
                  <strong>Send me a copy of this enquiry</strong>
                  <span>A confirmation email will be sent to your address above</span>
                </div>
              </label>
              <label class="qf-check-row">
                <input type="checkbox" name="open_to_retainer" value="Yes" />
                <div class="qf-check-text">
                  <strong>I'm open to a monthly retainer package</strong>
                  <span>Covering cleaning and/or HR — one invoice, one contact point</span>
                </div>
              </label>
            </div>

            <!-- Error message -->
            <div class="qf-error" id="qfError">Please fill in all required fields and select at least one service before submitting.</div>

            <div class="qf-footer">
              <div class="qf-footer-note">
                We respond within <strong>24 hours</strong><br>
                <span style="color:var(--warm-grey)">hello@amyserves.com · 09098104610</span>
              </div>
              <button type="submit" class="qf-submit" id="qfSubmit">
                Get a Quote →
              </button>
            </div>

          </div><!-- /.qf-body -->

          <!-- Formspree: send copy to submitter -->
          <input type="hidden" name="_replyto" id="replytoInput" value="" />
          <input type="hidden" name="_subject" value="New Quote Request — AmyServes" />

        </form>

        <!-- Google Form silent submission iframe -->
        <iframe name="hidden_iframe" id="hidden_iframe" style="display:none"></iframe>

      </div><!-- /.quote-form-card -->
    </div>
  </section>


