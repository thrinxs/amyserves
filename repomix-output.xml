              </label>
              <label style="display:flex;align-items:center;gap:12px;cursor:pointer;font-size:.875rem;color:var(--navy)">
                <input type="checkbox" id="notifMarketing" style="accent-color:var(--navy);width:16px;height:16px" />
                Receive tips and service updates from AmyServes
              </label>
            </div>
            <div style="display:flex;justify-content:flex-end;margin-top:16px">
              <button class="dash-btn dash-btn--primary" onclick="saveNotifications()">Save Preferences</button>
            </div>
          </div>
        </div>

        <!-- Danger Zone -->
        <div class="dash-card" style="border-color:rgba(220,50,70,0.2)">
          <div class="dash-card-header"><h3 style="color:#b71c1c">Danger Zone</h3></div>
          <div class="dash-card-body">
            <p style="font-size:.875rem;color:var(--warm-grey);margin-bottom:16px">These actions are irreversible. Please be certain before proceeding.</p>
            <div style="display:flex;gap:12px;flex-wrap:wrap">
              <button class="dash-btn dash-btn--danger" onclick="confirmDeleteAccount()">Delete My Account</button>
              <button id="signOutBtn" class="dash-btn dash-btn--secondary">Sign Out</button>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<div class="dash-toast" id="dashToast"></div>

<!-- Avatar Upload Modal -->
<div class="avatar-modal-overlay" id="avatarModal">
  <div class="avatar-modal">
    <div class="avatar-modal-header">
      <h3>Update Profile Photo</h3>
      <button class="avatar-modal-close" id="avatarModalClose">&times;</button>
    </div>

    <div class="avatar-modal-body">
      <!-- Current Photo Preview -->
      <div class="avatar-preview-section">
        <div class="avatar-preview-circle" id="avatarPreview">
          <span id="avatarPreviewInitials">CL</span>
          <img id="avatarPreviewImg" src="" alt="" style="display:none" />
        </div>
        <p class="avatar-preview-hint" id="avatarPreviewHint">Current photo</p>
      </div>

      <!-- Drop Zone -->
      <div class="avatar-dropzone" id="avatarDropzone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40" style="color:var(--warm-grey)">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="17 8 12 3 7 8"/>
          <line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
        <p class="dropzone-text">Drag & drop your photo here</p>
        <p class="dropzone-subtext">or</p>
        <button class="dropzone-browse-btn" id="avatarBrowseBtn">Browse Files</button>
        <p class="dropzone-hint">JPG, PNG or WebP · Max 2MB</p>
        <input type="file" id="avatarFileInput" accept="image/jpeg,image/png,image/webp" style="display:none" />
      </div>

      <!-- New Photo Preview (shown after selecting) -->
      <div class="avatar-new-preview" id="avatarNewPreview" style="display:none">
        <div class="avatar-new-preview-circle">
          <img id="avatarNewImg" src="" alt="New photo preview" />
        </div>
        <p class="avatar-new-filename" id="avatarNewFilename"></p>
        <button class="avatar-change-btn" id="avatarChangeBtn">Choose different photo</button>
      </div>
    </div>

    <div class="avatar-modal-footer">
      <button class="dash-btn dash-btn--ghost avatar-remove-btn" id="avatarRemoveBtn">Remove Photo</button>
      <div style="display:flex;gap:10px">
        <button class="dash-btn dash-btn--secondary" id="avatarCancelBtn">Cancel</button>
        <button class="dash-btn dash-btn--primary" id="avatarSaveBtn" disabled>Save Photo</button>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    'use strict';
  
    var selectedFile = null;
    var modal, dropzone, fileInput, saveBtn;
  
    document.addEventListener('DOMContentLoaded', function() {
      modal     = document.getElementById('avatarModal');
      dropzone  = document.getElementById('avatarDropzone');
      fileInput = document.getElementById('avatarFileInput');
      saveBtn   = document.getElementById('avatarSaveBtn');
  
      // Open modal
      var editBtn = document.getElementById('avatarEditBtn');
      var wrapper = document.getElementById('avatarWrapper');
      if (editBtn) editBtn.addEventListener('click', openAvatarModal);
      if (wrapper) wrapper.addEventListener('click', openAvatarModal);
  
      // Close modal
      var closeBtn  = document.getElementById('avatarModalClose');
      var cancelBtn = document.getElementById('avatarCancelBtn');
      if (closeBtn)  closeBtn.addEventListener('click', closeAvatarModal);
      if (cancelBtn) cancelBtn.addEventListener('click', closeAvatarModal);
  
      // Click overlay to close
      if (modal) {
        modal.addEventListener('click', function(e) {
          if (e.target === modal) closeAvatarModal();
        });
      }
  
      // Browse button
      var browseBtn = document.getElementById('avatarBrowseBtn');
      if (browseBtn) browseBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        fileInput.click();
      });
  
      // Dropzone click
      if (dropzone) dropzone.addEventListener('click', function() {
        fileInput.click();
      });
  
      // File selected
      if (fileInput) fileInput.addEventListener('change', function() {
        if (fileInput.files && fileInput.files[0]) handleFile(fileInput.files[0]);
      });
  
      // Drag and drop
      if (dropzone) {
        dropzone.addEventListener('dragover', function(e) {
          e.preventDefault();
          dropzone.classList.add('dragover');
        });
        dropzone.addEventListener('dragleave', function() {
          dropzone.classList.remove('dragover');
        });
        dropzone.addEventListener('drop', function(e) {
          e.preventDefault();
          dropzone.classList.remove('dragover');
          if (e.dataTransfer.files && e.dataTransfer.files[0]) {
            handleFile(e.dataTransfer.files[0]);
          }
        });
      }
  
      // Change photo button
      var changeBtn = document.getElementById('avatarChangeBtn');
      if (changeBtn) changeBtn.addEventListener('click', function() {
        resetToDropzone();
        fileInput.click();
      });
  
      // Save button
      if (saveBtn) saveBtn.addEventListener('click', uploadAvatar);
  
      // Remove button
      var removeBtn = document.getElementById('avatarRemoveBtn');
      if (removeBtn) removeBtn.addEventListener('click', removeAvatar);
  
      // Load current avatar
      loadCurrentAvatar();
    });
  
    function openAvatarModal() {
      if (modal) modal.classList.add('open');
    }
  
    function closeAvatarModal() {
      if (modal) modal.classList.remove('open');
      resetToDropzone();
      selectedFile = null;
    }
  
    function handleFile(file) {
      var validTypes = ['image/jpeg', 'image/png', 'image/webp'];
      if (validTypes.indexOf(file.type) === -1) {
        showToast('Please select a JPG, PNG, or WebP image.', 'error');
        return;
      }
  
      if (file.size > 2 * 1024 * 1024) {
        showToast('Image must be under 2MB.', 'error');
        return;
      }
  
      selectedFile = file;
  
      var reader = new FileReader();
      reader.onload = function(e) {
        var newPreview = document.getElementById('avatarNewPreview');
        var newImg     = document.getElementById('avatarNewImg');
        var filename   = document.getElementById('avatarNewFilename');
  
        if (newImg)     newImg.src = e.target.result;
        if (filename)   filename.textContent = file.name;
        if (newPreview) newPreview.style.display = 'block';
        if (dropzone)   dropzone.style.display = 'none';
        if (saveBtn)    saveBtn.disabled = false;
      };
      reader.readAsDataURL(file);
    }
  
    function resetToDropzone() {
      var newPreview = document.getElementById('avatarNewPreview');
      if (newPreview) newPreview.style.display = 'none';
      if (dropzone)   dropzone.style.display = '';
      if (saveBtn)    saveBtn.disabled = true;
      if (fileInput)  fileInput.value = '';
      selectedFile = null;
    }
  
    async function uploadAvatar() {
      if (!selectedFile || !supabaseClient) return;
  
      saveBtn.disabled = true;
      saveBtn.textContent = 'Uploading…';
  
      try {
        var sessionResult = await supabaseClient.auth.getSession();
        var session = sessionResult.data.session;
        if (!session || !session.user) throw new Error('Not logged in');
  
        var userId = session.user.id;
        var ext = selectedFile.name.split('.').pop().toLowerCase();
        var filePath = userId + '/avatar.' + ext;
  
        var { error: uploadError } = await supabaseClient.storage
          .from('avatars')
          .upload(filePath, selectedFile, {
            cacheControl: '3600',
            upsert: true
          });
  
        if (uploadError) throw uploadError;
  
        var { data: urlData } = supabaseClient.storage
          .from('avatars')
          .getPublicUrl(filePath);
  
        var avatarUrl = urlData.publicUrl + '?t=' + Date.now();
  
        var { error: dbError } = await supabaseClient
          .from('profiles')
          .update({ avatar_url: avatarUrl })
          .eq('id', userId);
  
        if (dbError) throw dbError;
  
        updateAvatarUI(avatarUrl);
        closeAvatarModal();
        showToast('Profile photo updated!', 'success');
  
      } catch (err) {
        console.error('Avatar upload error:', err);
        showToast('Failed to upload photo. ' + (err.message || ''), 'error');
      }
  
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Photo';
    }
  
    async function removeAvatar() {
      if (!supabaseClient) return;
  
      if (!confirm('Remove your profile photo?')) return;
  
      try {
        var sessionResult = await supabaseClient.auth.getSession();
        var session = sessionResult.data.session;
        if (!session || !session.user) return;
  
        var userId = session.user.id;
  
        await supabaseClient
          .from('profiles')
          .update({ avatar_url: null })
          .eq('id', userId);
  
        var extensions = ['jpg', 'jpeg', 'png', 'webp'];
        for (var i = 0; i < extensions.length; i++) {
          await supabaseClient.storage
            .from('avatars')
            .remove([userId + '/avatar.' + extensions[i]]);
        }
  
        updateAvatarUI(null);
        closeAvatarModal();
        showToast('Profile photo removed.', 'info');
  
      } catch (err) {
        console.error('Remove avatar error:', err);
        showToast('Failed to remove photo.', 'error');
      }
    }
  
    async function loadCurrentAvatar() {
      if (!supabaseClient) return;
  
      try {
        var sessionResult = await supabaseClient.auth.getSession();
        var session = sessionResult.data.session;
        if (!session || !session.user) return;
  
        var { data: profile } = await supabaseClient
          .from('profiles')
          .select('avatar_url, full_name, initials, color')
          .eq('id', session.user.id)
          .single();
  
        if (profile && profile.avatar_url) {
          updateAvatarUI(profile.avatar_url);
        }
      } catch (err) {
        console.warn('Load avatar warning:', err);
      }
    }
  
    function updateAvatarUI(url) {
      var profileAvatar = document.getElementById('profileAvatar');
      if (profileAvatar) {
        if (url) {
          profileAvatar.innerHTML = '<img src="' + url + '" alt="Profile photo" />';
        } else {
          var initials = profileAvatar.dataset.initials || 'CL';
          profileAvatar.textContent = initials;
        }
      }
  
      var previewImg      = document.getElementById('avatarPreviewImg');
      var previewInitials = document.getElementById('avatarPreviewInitials');
      if (url) {
        if (previewImg) { previewImg.src = url; previewImg.style.display = 'block'; }
        if (previewInitials) previewInitials.style.display = 'none';
      } else {
        if (previewImg) previewImg.style.display = 'none';
        if (previewInitials) previewInitials.style.display = '';
      }
  
      var sidebarAvatar = document.getElementById('sidebarAvatar');
      if (sidebarAvatar) {
        if (url) {
          sidebarAvatar.innerHTML = '<img src="' + url + '" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:50%" />';
        } else {
          var sideInitials = sidebarAvatar.dataset.initials || 'CL';
          sidebarAvatar.textContent = sideInitials;
        }
      }
  
      var hint = document.getElementById('avatarPreviewHint');
      if (hint) hint.textContent = url ? 'Current photo' : 'No photo set';
    }
  
    function showToast(msg, type) {
      var t = document.getElementById('dashToast');
      if (!t) return;
      t.textContent = msg;
      t.className = 'dash-toast show dash-toast--' + (type || 'info');
      setTimeout(function() { t.classList.remove('show'); }, 3000);
    }
  
  })();
  </script>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="../../js/supabase.js"></script>
<script src="../../js/dashboard-client.js"></script>

</body>
</html>
</file>

