            <!-- ── SECTION 1: Service -->
            <div class="qf-section-title">1 — Which service are you interested in?</div>

            <div class="qf-brand-grid">
              <div class="qf-brand-opt" id="opt-puraklen">
                <div class="qf-brand-name"><span class="qf-brand-dot qf-brand-dot--teal"></span>Pura-Kle'N</div>
                <div class="qf-brand-sub">Professional cleaning</div>
              </div>
              <div class="qf-brand-opt" id="opt-yourfirm">
                <div class="qf-brand-name"><span class="qf-brand-dot qf-brand-dot--purple"></span>Yourfirm Consults</div>
                <div class="qf-brand-sub">HR &amp; workforce consulting</div>
              </div>
              <div class="qf-brand-opt" id="opt-both">
                <div class="qf-brand-name"><span class="qf-brand-dot qf-brand-dot--gold"></span>Both Services</div>
                <div class="qf-brand-sub">Cleaning + HR together</div>
              </div>
            </div>

            <!-- Hidden brand input for Formspree -->
            <input type="hidden" name="brand" id="brandInput" value="" />

