/* ── READING PROGRESS ─────────────────────────────── */
.reading-progress {
    position: fixed;
    top: 0; left: 0;
    height: 3px;
    width: 0%;
    background: linear-gradient(90deg, var(--teal), var(--purple));
    z-index: 9999;
    transition: width 0.1s linear;
  }
  
  /* ── POST HERO ─────────────────────────────────────── */
  .post-hero {
    position: relative;
    min-height: 480px;
    display: flex;
    align-items: flex-end;
    padding-bottom: 48px;
    margin-top: 72px; /* navbar height */
  }
  .post-hero-image-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .post-hero-image {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .post-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15,21,35,0.85) 40%, rgba(15,21,35,0.3) 100%);
  }
  .post-hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }
  .post-back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(255,255,255,0.75);
    font-size: .875rem;
    font-weight: 500;
    margin-bottom: 16px;
    transition: var(--transition);
  }
  .post-back-link:hover { color: #fff; }
  
  .post-badge-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .post-featured-tag {
    background: var(--gold);
    color: #fff;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 20px;
  }
  
  .post-hero h1 {
    color: #fff;
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    line-height: 1.25;
    margin-bottom: 20px;
  }
  .post-meta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
