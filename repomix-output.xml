              <div class="qf-tags" id="serviceTags">
                <!-- Populated by JS based on brand selection -->
                <span style="font-size:0.85rem;color:var(--warm-grey);font-style:italic">Select a brand above to see services</span>
              </div>
              <input type="hidden" name="services_selected" id="servicesInput" value="" />
            </div>

            <!-- ── SECTION 2: Contact -->
