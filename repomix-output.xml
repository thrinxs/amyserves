  transform-origin: left;
  transition: transform 0.3s ease;
  border-radius: 3px 3px 0 0;
}
.pk-why-card:hover {
  border-color: var(--teal);
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
}
