  }
  
  /* Right side */
  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  
  .hero-brands-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 16px;
  }
  
  .hero-brand-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-md);
    padding: 18px 20px;
    margin-bottom: 12px;
