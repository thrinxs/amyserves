<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password — AmyServes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="../css/main.css" />
    <link rel="stylesheet" href="../css/auth.css" />
  </head>
  <body>

    <div class="auth-page">

      <!-- ── LEFT PANEL ───────────────────────────────── -->
      <div class="auth-panel">
        <div class="auth-panel-logo">
          <a href="../index.html">
            <img src="../assets/images/logos/amyserves.png" alt="AmyServes" />
          </a>
        </div>

        <div class="auth-panel-content">
          <h2>No worries — it happens to everyone</h2>
          <p>Enter your email and we'll send you a secure link to reset your password. It only takes a moment.</p>

          <div class="auth-features">
            <div class="auth-feature">
              <div class="auth-feature-icon">📧</div>
              <div class="auth-feature-text">
                <strong>Check your inbox</strong>
                <span>The reset link arrives within a few minutes</span>
              </div>
            </div>
            <div class="auth-feature">
              <div class="auth-feature-icon">⏱️</div>
              <div class="auth-feature-text">
                <strong>Link expires in 1 hour</strong>
                <span>Request a new one if it expires</span>
              </div>
            </div>
          </div>
        </div>

        <div class="auth-panel-footer">
          <p>© 2026 AmyServes Group · Abuja, Nigeria</p>
        </div>
      </div>

      <!-- ── RIGHT PANEL (FORM) ────────────────────────── -->
      <div class="auth-form-section">
        <div class="auth-form-box">

          <div class="auth-mobile-logo">
            <a href="../index.html">
              <img src="../assets/images/logos/amyserves.png" alt="AmyServes" />
            </a>
          </div>

          <!-- Default state -->
          <div id="formState">
            <h1>Reset password</h1>
            <p class="auth-subtitle">
              Remembered it? <a href="login.html">Back to sign in</a>
            </p>

            <div class="auth-alert error" id="resetAlert"></div>

            <div class="form-group">
              <label for="email">Email address</label>
              <input type="email" id="email" placeholder="you@example.com" autocomplete="email" />
              <span class="field-error" id="emailError"></span>
            </div>

            <button class="btn-auth" id="resetBtn" onclick="handleReset()">
              <span class="spinner"></span>
              <span class="btn-text">Send reset link</span>
            </button>
          </div>

          <!-- Success state (shown after submission) -->
          <div id="successState" style="display:none; text-align:center; padding: 20px 0;">
            <div style="font-size:3rem; margin-bottom:16px;">📬</div>
            <h2 style="font-size:1.5rem; margin-bottom:12px;">Check your email</h2>
            <p style="color:var(--warm-grey); margin-bottom:28px; font-size:0.95rem;">
              We sent a reset link to <strong id="sentTo" style="color:var(--navy)"></strong>. 
              It expires in 1 hour.
            </p>
            <a href="login.html" class="btn-auth" style="text-decoration:none; display:inline-flex;">
              Back to sign in
            </a>
            <p style="margin-top:20px; font-size:0.82rem; color:var(--warm-grey);">
              Didn't get it? <button onclick="handleReset()" style="background:none;border:none;color:var(--teal);font-weight:600;cursor:pointer;font-size:0.82rem;">Resend</button>
            </p>
          </div>

        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="../js/supabase.js"></script>
    <script src="../js/auth-login.js"></script>
  </body>
</html>
