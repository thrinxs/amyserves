<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Notifications — AmyServes Client Portal</title>
  <link rel="stylesheet" href="../../css/main.css" />
  <link rel="stylesheet" href="../../css/dashboard.css" />
  <style>
    body { opacity: 0; transition: opacity 0.3s ease; }
    body.auth-ready { opacity: 1; }

    /* ── TABS ── */
    .notif-tabs {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    .notif-tab {
      padding: 7px 16px;
      border-radius: 20px;
      border: 1.5px solid #e0dbd4;
      background: #fff;
      font-size: .82rem;
      font-weight: 600;
      color: var(--warm-grey);
      cursor: pointer;
      transition: all 0.2s;
    }

    .notif-tab.active {
      background: var(--navy);
      color: #fff;
      border-color: var(--navy);
    }

    .notif-tab:hover:not(.active) {
      border-color: var(--navy);
      color: var(--navy);
    }

    /* ── NOTIFICATION ITEMS ── */
    .notif-page-item {
      display: flex;
      gap: 16px;
      padding: 18px 24px;
      border-bottom: 1px solid #f0ede8;
      cursor: pointer;
      transition: background 0.2s;
    }

    .notif-page-item:hover {
      background: #faf8f5;
    }

    .notif-page-item.unread {
      background: #fffbf2;
      border-left: 3px solid var(--gold);
    }

    .notif-page-item:last-child {
      border-bottom: none;
    }

    .notif-icon {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      flex-shrink: 0;
    }

    .notif-icon.booking  { background: #e8f5e9; }
    .notif-icon.message  { background: #e3f2fd; }
    .notif-icon.status_update { background: #fff3e0; }
    .notif-icon.general  { background: #f3f0ff; }
    .notif-icon.sent     { background: #f0fdf4; }

    .notif-body {
      flex: 1;
      min-width: 0;
    }

    .notif-title-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 4px;
    }

    .notif-title {
      font-size: .92rem;
      color: var(--navy);
    }

    .notif-title.bold {
      font-weight: 700;
    }

    .notif-time {
      font-size: .75rem;
      color: var(--warm-grey);
      white-space: nowrap;
    }

    .notif-text {
      font-size: .85rem;
      color: #555;
      line-height: 1.5;
    }

    .notif-direction-badge {
      display: inline-block;
      font-size: .7rem;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 10px;
      margin-top: 6px;
    }

    .notif-direction-badge.received {
      background: #e3f2fd;
      color: #1565c0;
    }

    .notif-direction-badge.sent {
      background: #e8f5e9;
      color: #2e7d32;
    }

    .notif-unread-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--gold);
      flex-shrink: 0;
      margin-top: 6px;
    }

    .notif-empty {
      padding: 48px 24px;
      text-align: center;
    }

    .notif-empty span {
      font-size: 2rem;
      display: block;
      margin-bottom: 12px;
    }

    .notif-empty h4 {
      margin: 0 0 4px;
      color: var(--navy);
    }

    .notif-empty p {
      color: var(--warm-grey);
      font-size: .9rem;
      margin: 0;
    }
  </style>
</head>
<body>

<div id="dashSidebarOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:99"></div>

<div class="dash-page">

