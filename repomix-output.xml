    initIndexPage();
    initMessagesPage();
    initProfilePage();
    await initNotifications();

    // Wire up ALL sign out buttons
    var signOutIds = ['sidebarSignOutBtn', 'topbarSignOutBtn', 'signOutBtn'];
    signOutIds.forEach(function (id) {
      var btn = document.getElementById(id);
      if (btn) btn.addEventListener('click', handleSignOut);
    });

    // Reveal the page
    document.body.classList.add('auth-ready');
  });

})();
