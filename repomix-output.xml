<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="../../js/supabase.js"></script>
<script src="../../js/dashboard-client.js"></script>

<script>
  (function () {
    'use strict';
  
    var allNotifications = [];
    var currentFilter    = 'all';
  
    var icons = {
      booking:       '📋',
      message:       '💬',
      status_update: '🔄',
      general:       '🔔',
      sent:          '📤'
    };
  
    /* ── INIT ── */
    document.addEventListener('DOMContentLoaded', async function () {
      await waitForAuth();
      await loadNotifications();
  
      // Tab clicks
      document.querySelectorAll('.notif-tab').forEach(function (tab) {
        tab.addEventListener('click', function () {
          document.querySelectorAll('.notif-tab').forEach(function (t) {
            t.classList.remove('active');
          });
          tab.classList.add('active');
          currentFilter = tab.dataset.filter;
          renderNotifications();
        });
      });
  
      // Mark all read
      var markAllBtn = document.getElementById('markAllReadPage');
      if (markAllBtn) {
        markAllBtn.addEventListener('click', markAllAsRead);
      }
    });
  
    /* ── WAIT FOR AUTH ── */
    async function waitForAuth() {
      return new Promise(function (resolve) {
        var tries = 0;
        var check = setInterval(function () {
          tries++;
          if (typeof supabaseClient !== 'undefined' && supabaseClient) {
            clearInterval(check);
            resolve();
          }
          if (tries > 50) {
            clearInterval(check);
            resolve();
          }
        }, 100);
      });
    }
  
    /* ── GET USER ID ── */
    async function getUserId() {
      if (!supabaseClient) return null;
      var sessionResult = await supabaseClient.auth.getSession();
      var session = sessionResult.data.session;
      if (!session || !session.user) return null;
      return session.user.id;
    }
  
    /* ── LOAD ── */
    async function loadNotifications() {
      var userId = await getUserId();
      if (!userId) return;
  
      var { data, error } = await supabaseClient
        .from('notifications')
        .select('*')
        .eq('user_id', userId)
        .order('created_at', { ascending: false });
  
      if (error) {
        console.error('Load notifications error:', error);
        return;
      }
  
      allNotifications = data || [];
      renderNotifications();
      updatePageBadges();
    }
  
    /* ── RENDER ── */
    function renderNotifications() {
      var list = document.getElementById('notificationsPageList');
      if (!list) return;
  
      var filtered = allNotifications.filter(function (n) {
        if (currentFilter === 'all')      return true;
        if (currentFilter === 'received') return n.direction === 'received' || !n.direction;
        if (currentFilter === 'sent')     return n.direction === 'sent';
        if (currentFilter === 'unread')   return !n.is_read;
        if (currentFilter === 'read')     return n.is_read;
        return true;
      });
  
      if (filtered.length === 0) {
        var labels = {
          all:      'No notifications yet',
          received: 'No received notifications',
          sent:     'No sent notifications',
          unread:   'No unread notifications',
          read:     'No read notifications'
        };
        list.innerHTML = '<div class="notif-empty">'
          + '<span>🔔</span>'
          + '<h4>' + (labels[currentFilter] || 'Nothing here') + '</h4>'
          + '<p>When you receive updates, yourfirmci@gmail.com appear here.</p>'
          + '</div>';
        return;
      }
  
      list.innerHTML = filtered.map(function (n) {
        var icon      = icons[n.type] || '🔔';
        var direction = n.direction || 'received';
        var isUnread  = !n.is_read;
  
        return '<div class="notif-page-item' + (isUnread ? ' unread' : '') + '" data-id="' + n.id + '">'
          + '<div class="notif-icon ' + (n.type || 'general') + '">' + icon + '</div>'
          + '<div class="notif-body">'
            + '<div class="notif-title-row">'
              + '<div class="notif-title' + (isUnread ? ' bold' : '') + '">' + n.title + '</div>'
              + '<div class="notif-time">' + timeAgo(n.created_at) + '</div>'
            + '</div>'
            + '<div class="notif-text">' + n.body + '</div>'
            + '<span class="notif-direction-badge ' + direction + '">'
              + (direction === 'sent' ? '↑ Sent' : '↓ Received')
            + '</span>'
          + '</div>'
          + (isUnread ? '<div class="notif-unread-dot"></div>' : '')
          + '</div>';
      }).join('');
  
      // Click to mark as read
      list.querySelectorAll('.notif-page-item').forEach(function (item) {
        item.addEventListener('click', async function () {
          var id    = item.dataset.id;
          var notif = allNotifications.find(function (n) { return n.id === id; });
          if (!notif || notif.is_read) return;
  
          await supabaseClient
            .from('notifications')
            .update({ is_read: true })
            .eq('id', id);
  
          notif.is_read = true;
          renderNotifications();
          updatePageBadges();
        });
      });
    }
  
    /* ── MARK ALL READ ── */
    async function markAllAsRead() {
      var userId = await getUserId();
      if (!userId) return;
  
      await supabaseClient
        .from('notifications')
        .update({ is_read: true })
        .eq('user_id', userId)
        .eq('is_read', false);
  
      allNotifications.forEach(function (n) { n.is_read = true; });
      renderNotifications();
      updatePageBadges();
  
      var toast = document.getElementById('dashToast');
      if (toast) {
        toast.textContent = 'All notifications marked as read';
        toast.className   = 'dash-toast show dash-toast--success';
        setTimeout(function () { toast.classList.remove('show'); }, 3000);
      }
    }
  
    /* ── UPDATE BADGES ── */
    function updatePageBadges() {
      var unread   = allNotifications.filter(function (n) { return !n.is_read; }).length;
      var bell     = document.getElementById('notifCount');
      var navBadge = document.getElementById('notifNavBadge');
  
      if (bell) {
        bell.textContent    = unread;
        bell.style.display  = unread > 0 ? 'flex' : 'none';
      }
      if (navBadge) {
        navBadge.textContent   = unread;
        navBadge.style.display = unread > 0 ? 'inline-flex' : 'none';
      }
    }
  
    /* ── TIME AGO ── */
    function timeAgo(dateStr) {
      var now  = new Date();
      var date = new Date(dateStr);
      var diff = Math.floor((now - date) / 1000);
      if (diff < 60)     return 'Just now';
      if (diff < 3600)   return Math.floor(diff / 60)   + 'm ago';
      if (diff < 86400)  return Math.floor(diff / 3600)  + 'h ago';
      if (diff < 604800) return Math.floor(diff / 86400) + 'd ago';
      return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
    }
  
  })();
  </script>

</body>
</html>
