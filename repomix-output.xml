      document.querySelectorAll('.auth-tab').forEach(function(tab) {
        tab.addEventListener('click', function() {
          var t = tab.dataset.tab;
          document.querySelectorAll('.auth-tab').forEach(function(x) { x.classList.remove('active'); });
