          <div class="dash-stat-change dash-stat-change--up">↑ 3 this week</div>
        </div>
        <div class="dash-stat-card">
          <div class="dash-stat-icon dash-stat-icon--gold">⏳</div>
          <div class="dash-stat-value" id="statPending">—</div>
          <div class="dash-stat-label">Pending</div>
          <div class="dash-stat-change dash-stat-change--neu">Needs attention</div>
        </div>
        <div class="dash-stat-card">
          <div class="dash-stat-icon dash-stat-icon--teal">🔄</div>
          <div class="dash-stat-value" id="statInProgress">—</div>
          <div class="dash-stat-label">In Progress</div>
          <div class="dash-stat-change dash-stat-change--up">Active engagements</div>
        </div>
        <div class="dash-stat-card">
          <div class="dash-stat-icon dash-stat-icon--purple">💬</div>
          <div class="dash-stat-value" id="statMessages">—</div>
          <div class="dash-stat-label">Unread Messages</div>
          <div class="dash-stat-change dash-stat-change--neu">Requires reply</div>
        </div>
      </div>

      <!-- Two columns -->
      <div class="dash-grid-2">

        <!-- Recent Requests -->
        <div class="dash-card" style="grid-column:1 / -1">
          <div class="dash-card-header">
            <h3>Recent Service Requests</h3>
            <a href="requests.html" class="dash-btn dash-btn--secondary dash-btn--sm">View All</a>
          </div>
          <div class="dash-table-wrap">
            <table class="dash-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Client</th>
                  <th>Service</th>
                  <th>Date</th>
                  <th>Status</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="recentRequestsBody">
                <tr><td colspan="6" style="text-align:center;padding:24px;color:var(--warm-grey)">Loading…</td></tr>
              </tbody>
            </table>
          </div>
        </div>

      </div>

      <!-- Activity + Quick actions -->
      <div class="dash-grid-2" style="margin-top:0">
        <div class="dash-card">
          <div class="dash-card-header">
            <h3>Recent Activity</h3>
          </div>
          <div class="dash-card-body">
            <div class="dash-feed" id="activityFeed">
              <div style="color:var(--warm-grey);font-size:.875rem">Loading…</div>
            </div>
          </div>
        </div>

        <div class="dash-card">
          <div class="dash-card-header">
            <h3>Quick Actions</h3>
          </div>
          <div class="dash-card-body" style="display:flex;flex-direction:column;gap:10px">
            <a href="messages.html" class="dash-btn dash-btn--primary" style="width:100%;justify-content:center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              View All Messages
            </a>
            <a href="requests.html" class="dash-btn dash-btn--secondary" style="width:100%;justify-content:center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
              Manage Requests
            </a>
            <a href="users.html" class="dash-btn dash-btn--secondary" style="width:100%;justify-content:center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
              View Users
            </a>
            <a href="blog.html" class="dash-btn dash-btn--secondary" style="width:100%;justify-content:center">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              Manage Blog
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>

</div>

<div class="dash-toast" id="dashToast"></div>

<script src="../../js/supabase.js"></script>
<script src="../../js/auth.js"></script>
<script src="../../js/dashboard-admin.js"></script>
</body>
</html>
