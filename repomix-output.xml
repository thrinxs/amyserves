        </div>
        <div class="dash-form-group"><label>Author</label><input type="text" value="Chiamaka (Amy)" /></div>
      </div>
      <div class="dash-form-group"><label>Content (HTML)</label><textarea rows="8" placeholder="Article content goes here…"></textarea></div>
      <p style="font-size:.82rem;color:var(--warm-grey);margin-top:8px">Full rich-text editor will be available in Phase 5 with Supabase integration.</p>
    </div>
    <div class="dash-modal-footer">
      <button class="dash-btn dash-btn--secondary" onclick="closeNewPostModal()">Cancel</button>
      <button class="dash-btn dash-btn--primary" onclick="showToast('Post saved as draft. Publishing requires Supabase.','info');closeNewPostModal()">Save Draft</button>
    </div>
  </div>
</div>

<div class="dash-toast" id="dashToast"></div>

<script>
var posts = [
  { title: 'Why Nigerian SMEs Keep Getting HR Wrong', category: 'HR & People', author: 'Chiamaka (Amy)', date: 'Mar 20, 2026', likes: 47, status: 'published' },
  { title: 'The Hidden Cost of a Dirty Office', category: 'Cleaning & Hygiene', author: 'Operations Team', date: 'Mar 15, 2026', likes: 31, status: 'published' },
  { title: 'Scaling an SME in Nigeria: 5 Operational Gaps', category: 'Business Growth', author: 'Chiamaka (Amy)', date: 'Mar 10, 2026', likes: 58, status: 'published' },
  { title: 'CAC Registration, PAYE & NHF: Compliance Checklist', category: 'Compliance & Legal', author: 'HR Lead', date: 'Mar 5, 2026', likes: 24, status: 'published' },
  { title: 'How to Write an Employment Contract', category: 'HR & People', author: 'HR Lead', date: 'Feb 28, 2026', likes: 39, status: 'published' },
  { title: 'Post-Construction Cleaning Before Handover', category: 'Cleaning & Hygiene', author: 'Operations Team', date: 'Feb 20, 2026', likes: 19, status: 'published' }
];

var catMap = { 'HR & People': 'purple', 'Cleaning & Hygiene': 'teal', 'Business Growth': 'gold', 'Compliance & Legal': 'navy' };

function renderBlog() {
  var tbody = document.getElementById('blogTableBody');
  tbody.innerHTML = posts.map(function(p, i) {
    return '<tr>'
      + '<td style="max-width:280px"><strong style="font-size:.875rem">'+p.title+'</strong></td>'
      + '<td><span class="dash-badge dash-badge--'+(catMap[p.category]||'grey')+'">'+p.category+'</span></td>'
      + '<td style="font-size:.82rem">'+p.author+'</td>'
      + '<td style="font-size:.82rem;color:var(--warm-grey)">'+p.date+'</td>'
      + '<td style="font-size:.82rem">♥ '+p.likes+'</td>'
      + '<td><span class="dash-badge dash-badge--green">Published</span></td>'
      + '<td><div style="display:flex;gap:6px">'
        + '<a href="../../blog-post.html?id='+(i+1)+'" target="_blank" class="dash-btn dash-btn--secondary dash-btn--sm">View</a>'
        + '<button class="dash-btn dash-btn--secondary dash-btn--sm" onclick="showToast(\'Edit mode coming in Phase 5.\',\'info\')">Edit</button>'
      + '</div></td>'
      + '</tr>';
  }).join('');
}

function openNewPostModal() { document.getElementById('newPostModal').classList.add('open'); }
function closeNewPostModal() { document.getElementById('newPostModal').classList.remove('open'); }

var toastTimer;
function showToast(msg, type) {
  var t = document.getElementById('dashToast');
  t.textContent = msg;
  t.className = 'dash-toast show dash-toast--'+(type||'info');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(function(){t.classList.remove('show');}, 3000);
}

document.addEventListener('DOMContentLoaded', function(){
  renderBlog();
  document.getElementById('dashMenuToggle').addEventListener('click', function(){
    document.getElementById('dashSidebar').classList.toggle('open');
  });
});
</script>
</body>
</html>
