  { id: 4, name: 'Ngozi Eze', email: 'ngozi@ezeproperties.ng', phone: '09098104610', service: 'Cleaning', role: 'client', joined: '27 Mar 2026', avatar: '#C8941A' },
  { id: 5, name: 'HR Lead', email: 'hr@amyserves.com', phone: '09098104610', service: 'Internal', role: 'staff', joined: '1 Jan 2026', avatar: '#3C3489' },
  { id: 6, name: 'Chiamaka (Amy)', email: 'hello@amyserves.com', phone: '09098104610', service: 'Internal', role: 'admin', joined: '1 Jan 2025', avatar: '#1A3C5E' }
];

var filtered = mockUsers.slice();

function getInitials(name) {
  return name.split(' ').map(function(w){return w[0];}).join('').slice(0,2).toUpperCase();
}

function roleBadge(role) {
  var map = { admin: 'navy', staff: 'teal', client: 'grey' };
  return '<span class="dash-badge dash-badge--' + (map[role]||'grey') + '">' + role.charAt(0).toUpperCase() + role.slice(1) + '</span>';
}

function renderUsers() {
  var tbody = document.getElementById('usersTableBody');
  if (filtered.length === 0) {
    tbody.innerHTML = '<tr><td colspan="7"><div class="dash-empty"><span>👤</span><h4>No users found</h4></div></td></tr>';
    return;
  }
  tbody.innerHTML = filtered.map(function(u) {
    return '<tr>'
      + '<td><div style="display:flex;align-items:center;gap:10px"><div style="width:32px;height:32px;border-radius:50%;background:'+u.avatar+';display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;color:#fff;flex-shrink:0">'+getInitials(u.name)+'</div><strong>'+u.name+'</strong></div></td>'
      + '<td style="font-size:.82rem">'+u.email+'</td>'
      + '<td style="font-size:.82rem">'+u.phone+'</td>'
      + '<td><span class="dash-badge dash-badge--grey">'+u.service+'</span></td>'
      + '<td>'+roleBadge(u.role)+'</td>'
      + '<td style="font-size:.82rem;color:var(--warm-grey)">'+u.joined+'</td>'
      + '<td><button class="dash-btn dash-btn--secondary dash-btn--sm" onclick="showToast(\'Feature coming with Supabase integration.\',\'info\')">Edit</button></td>'
      + '</tr>';
  }).join('');
}

function filterUsers(q) {
  var lq = q.toLowerCase();
  filtered = mockUsers.filter(function(u){ return !lq || u.name.toLowerCase().indexOf(lq)>-1 || u.email.toLowerCase().indexOf(lq)>-1; });
  renderUsers();
}

function filterUsersByRole(role) {
  filtered = role==='all' ? mockUsers.slice() : mockUsers.filter(function(u){return u.role===role;});
  renderUsers();
}

var toastTimer;
function showToast(msg, type) {
  var t = document.getElementById('dashToast');
  t.textContent = msg;
  t.className = 'dash-toast show dash-toast--'+(type||'info');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(function(){t.classList.remove('show');}, 3000);
}

document.addEventListener('DOMContentLoaded', function(){
  renderUsers();
  document.getElementById('dashMenuToggle').addEventListener('click', function(){
    document.getElementById('dashSidebar').classList.toggle('open');
  });
});
</script>
