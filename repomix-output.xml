  .post-meta-row .blog-author-chip { color: rgba(255,255,255,0.9); }
  .post-meta-row .blog-author-chip span { color: rgba(255,255,255,0.9); }
  .post-like-summary { color: rgba(255,255,255,0.7); }
  
  /* ── MAIN LAYOUT ───────────────────────────────────── */
  .post-main { padding: 60px 0 80px; }
