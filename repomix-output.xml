/* ── SHARED LAYOUT ─────────────────────────────────── */
.pk-section {
  padding: 88px 0;
}
.pk-section-light  { background: var(--white); }
.pk-section-cream  { background: var(--cream); }
.pk-section-dark   { background: var(--navy-dark); position: relative; overflow: hidden; }
.pk-section-dark::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 60% 60% at 90% 20%, rgba(15,110,86,0.14) 0%, transparent 60%),
    radial-gradient(ellipse 40% 50% at 10% 80%, rgba(15,110,86,0.08) 0%, transparent 60%);
  pointer-events: none;
}
.pk-section-dark .container { position: relative; z-index: 1; }

.pk-section-header {
  text-align: center;
  max-width: 620px;
  margin: 0 auto 56px;
}
.pk-section-header h2 { margin-bottom: 14px; }
.pk-section-header p  { color: var(--warm-grey); font-size: 1rem; line-height: 1.75; }

.pk-section-header--light { color: var(--white); }
.pk-section-header--light h2 { color: var(--white); }

.text-white { color: var(--white) !important; }
.text-muted { color: rgba(255,255,255,0.5) !important; }

/* ── EYEBROW ───────────────────────────────────────── */
.pk-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 14px;
}
.pk-eyebrow::before {
  content: '';
  display: inline-block;
  width: 24px; height: 2px;
  background: var(--teal);
  border-radius: 2px;
  flex-shrink: 0;
}
.pk-eyebrow--gold   { color: var(--gold-light); }
.pk-eyebrow--gold::before { background: var(--gold); }


/* ══════════════════════════════════════════════════════
   HERO
══════════════════════════════════════════════════════ */
.pk-hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
}

/* Slideshow */
.pk-slideshow {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.pk-slide {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  opacity: 0;
  transition: opacity 1.2s ease;
}
.pk-slide.active { opacity: 1; }
.pk-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(10, 35, 25, 0.88) 0%,
    rgba(15, 40, 30, 0.78) 40%,
    rgba(10, 25, 20, 0.72) 100%
  );
}

.pk-hero .container {
  position: relative;
  z-index: 1;
  padding-top: 80px;
  padding-bottom: 80px;
}

.pk-hero-content { max-width: 760px; }

/* Badge */
.pk-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: rgba(15,110,86,0.2);
  border: 1px solid rgba(15,110,86,0.4);
  border-radius: 100px;
  padding: 7px 16px 7px 10px;
  margin-bottom: 28px;
  font-size: 0.78rem;
  font-weight: 600;
  color: rgba(255,255,255,0.75);
  letter-spacing: 0.5px;
}
.pk-badge-logo {
  height: 24px;
  width: auto;
  object-fit: contain;
  filter: brightness(0) invert(1);
  opacity: 0.85;
}

/* Title */
.pk-hero-title {
  font-size: clamp(2.4rem, 5.5vw, 4rem);
  font-weight: 800;
  color: var(--white);
  line-height: 1.08;
  margin-bottom: 22px;
  letter-spacing: -0.5px;
}
.pk-hero-accent {
  color: var(--teal-light);
  position: relative;
}
.pk-hero-accent::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--teal), transparent);
  border-radius: 2px;
}

.pk-hero-subtitle {
  font-size: 1.05rem;
  color: rgba(255,255,255,0.62);
  max-width: 520px;
  line-height: 1.78;
  margin-bottom: 36px;
}

/* CTAs */
.pk-hero-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 48px;
}

.pk-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 13px 28px;
  border-radius: var(--radius-sm);
  font-size: 0.92rem;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.25s ease;
  border: 2px solid transparent;
  cursor: pointer;
  font-family: inherit;
  white-space: nowrap;
}
.pk-btn-teal {
  background: var(--teal);
  color: var(--white);
  border-color: var(--teal);
}
.pk-btn-teal:hover {
  background: var(--teal-light);
  border-color: var(--teal-light);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(15,110,86,0.4);
}
.pk-btn-ghost {
  background: transparent;
  color: rgba(255,255,255,0.8);
  border-color: rgba(255,255,255,0.25);
}
.pk-btn-ghost:hover {
  border-color: rgba(255,255,255,0.6);
  color: var(--white);
  transform: translateY(-2px);
}
.pk-btn-gold {
  background: var(--gold);
  color: var(--navy-dark);
  border-color: var(--gold);
}
.pk-btn-gold:hover {
  background: var(--gold-light);
  border-color: var(--gold-light);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(200,148,26,0.4);
}
.pk-btn-ghost-light {
  background: transparent;
  color: rgba(255,255,255,0.7);
  border-color: rgba(255,255,255,0.2);
}
.pk-btn-ghost-light:hover {
  border-color: rgba(255,255,255,0.5);
  color: var(--white);
}

/* Stats */
.pk-hero-stats {
  display: flex;
  align-items: center;
  gap: 32px;
  flex-wrap: wrap;
}
.pk-stat { text-align: left; }
.pk-stat-num {
  font-size: 2rem;
  font-weight: 800;
  color: var(--white);
  line-height: 1;
}
.pk-stat-plus {
  font-size: 1.4rem;
  font-weight: 800;
  color: var(--teal-light);
}
.pk-stat-label {
  display: block;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.4);
  margin-top: 3px;
  letter-spacing: 0.5px;
}
.pk-stat-divider {
  width: 1px;
  height: 40px;
  background: rgba(255,255,255,0.12);
  flex-shrink: 0;
}

/* Slideshow dots */
.pk-dots {
  position: absolute;
  bottom: 36px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 8px;
}
.pk-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  cursor: pointer;
  transition: all 0.3s ease;
}
.pk-dot.active {
  background: var(--teal-light);
  width: 24px;
  border-radius: 4px;
}


/* ══════════════════════════════════════════════════════
   WHY PURA-KLE'N
══════════════════════════════════════════════════════ */
.pk-why-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
